# .env.development — 开发环境变量
# ============================================================================
# 开发时使用 Vite dev server 的 proxy 转发，所以 API_BASE 和 SOCKET_URL 留空
# 请求会走同源路径 /api/... → proxy → localhost:3000

# 后端 API 地址（开发时留空 = 使用 Vite proxy）
VITE_API_BASE=

# Socket.IO 地址（开发时留空 = 使用 Vite proxy + ws）
VITE_SOCKET_URL=
