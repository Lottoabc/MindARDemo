# .env.production — 生产环境变量（GitHub Pages 部署用）
# ============================================================================
# 【重要】构建前请将下面的 URL 替换为你的实际后端地址！
#
# 如何获取后端 URL：
#   1. 将 server/ 部署到 Render（免费）→ 获得 https://xxx.onrender.com
#   2. 或者部署到 Railway / Fly.io 等平台
#   3. 将获得的 URL 填入下方

# 后端 API 地址（必须带 https://，末尾不带斜杠）
VITE_API_BASE=https://webar-server.onrender.com

# Socket.IO 地址（通常与 API_BASE 相同，如不同则单独配置）
VITE_SOCKET_URL=https://webar-server.onrender.com
